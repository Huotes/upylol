# ╔══════════════════════════════════════════════════════════════╗
# ║  UPYLOL — Environment Variables                             ║
# ║  Copie para .env e preencha os valores                      ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Riot Games API ───────────────────────────────────────────
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RIOT_DEFAULT_REGION=br1

# ── Database (PostgreSQL) ────────────────────────────────────
DB_NAME=upylol
DB_USER=upylol
DB_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://upylol:change_me_in_production@db:5432/upylol

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Backend (FastAPI) ────────────────────────────────────────
DEBUG=true
APP_NAME=UPYLOL
APP_VERSION=0.1.0
CORS_ORIGINS=["http://localhost:3000","http://localhost:80","http://localhost"]
BACKEND_WORKERS=4

# Cache TTLs (seconds)
CACHE_TTL_PLAYER=300
CACHE_TTL_MATCHES=120
CACHE_TTL_ANALYSIS=600

# ── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api
DDRAGON_VERSION=15.3.1

# ── Nginx ────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Observability (opcional) ─────────────────────────────────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
