# ╔══════════════════════════════════════════════════════════════╗
# ║  UPYLOL — EditorConfig                                      ║
# ║  Garante estilo consistente em qualquer editor               ║
# ╚══════════════════════════════════════════════════════════════╝

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python
[*.py]
indent_size = 4
max_line_length = 99

# Makefile (requires tabs)
[Makefile]
indent_style = tab
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 4

# SQL
[*.sql]
indent_size = 4

# YAML
[*.{yml,yaml}]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# Docker
[Dockerfile*]
indent_size = 4
